{
  "app": "mvn -e -q compile exec:java -pl cdk-app",
  "watch": {
    "include": ["**"],
    "exclude": [
      "README.md",
      "cdk*.json",
      "target",
      "pom.xml",
      "lambdas/**/target"
    ]
  },
  "context": {
    "@aws-cdk/aws-lambda:recognizeVersionProps": true,
    "@aws-cdk/core:newStyleStackSynthesis": true
  }
}
